# 环境变量模板 - 复制为 .env 并填入实际值
NODE_ENV=development

# 数据库
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/decoration_bidding

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin@localhost:5672

# JWT
JWT_SECRET=dev-secret-change-in-production

# 文件存储 (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=decoration-bidding

# LLM API Keys（支持任意 OpenAI 兼容接口，如 Kimi、DeepSeek 等）
LLM_API_KEY=            # 主 API Key（优先级高于 OPENAI_API_KEY）
LLM_BASE_URL=           # 自定义接口地址，如 https://api.moonshot.cn/v1（留空则用 OpenAI 官方）
LLM_SUPPORTS_VISION=true  # 模型是否支持图片输入；moonshot-v1-8k 等纯文本模型设为 false
DEFAULT_LLM_MODEL=kimi-k2.6  # 模型名，Kimi 2.5 可用 moonshot-v1-128k 等

# 兼容旧变量名
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 文件存储（local = 本地磁盘；s3 = S3/MinIO）
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# 前端
NEXT_PUBLIC_API_URL=http://localhost:8080

# 邮件服务 (SMTP)
# 填写你的 SMTP 服务器信息，用于发送邀请邮件、重置密码邮件等
SMTP_HOST=smtp.example.com        # SMTP 服务器地址，如 smtp.qq.com / smtp.163.com / smtp.exmail.qq.com
SMTP_PORT=587                      # 端口：587(TLS/STARTTLS) 或 465(SSL) 或 25
SMTP_USER=your@example.com        # 邮箱账号
SMTP_PASS=your-smtp-password       # 邮箱密码或应用专用密码
SMTP_FROM=noreply@example.com     # 发件人地址（建议与 SMTP_USER 一致）

# Langfuse（可观测性追踪，填写你的独立部署地址和 API Keys）
LANGFUSE_BASE_URL=http://localhost:3030
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key