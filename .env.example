# 环境变量模板 - 复制为 .env 并填入实际值
NODE_ENV=development

# 数据库
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/decoration_bidding

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin@localhost:5672

# JWT
JWT_SECRET=dev-secret-change-in-production

# 文件存储 (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=decoration-bidding

# LLM API Keys（支持任意 OpenAI 兼容接口，如 Kimi、DeepSeek 等）
LLM_API_KEY=            # 主 API Key（优先级高于 OPENAI_API_KEY）
LLM_BASE_URL=           # 自定义接口地址，如 https://api.moonshot.cn/v1（留空则用 OpenAI 官方）
LLM_SUPPORTS_VISION=true  # 模型是否支持图片输入；moonshot-v1-8k 等纯文本模型设为 false
DEFAULT_LLM_MODEL=kimi-k2.6  # 模型名，Kimi 2.5 可用 moonshot-v1-128k 等

# 兼容旧变量名
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# 前端
NEXT_PUBLIC_API_URL=http://localhost:8080

# Langfuse（可观测性追踪，填写你的独立部署地址和 API Keys）
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key